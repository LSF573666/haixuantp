# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=voting_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# 短信验证码（开发环境可使用固定验证码 123456）
SMS_DEV_MODE=True
SMS_DEV_CODE=123456

# 阿里云 OSS（配置后上传文件将存储到 OSS）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
ALIYUN_OSS_BUCKET=
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BASE_URL=
OSS_STS_ROLE_ARN=

# 阿里云短信（SMS_DEV_MODE=False 时生效）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION=cn-hangzhou
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# 微信支付
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/payments/wechat/notify/

# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=keys/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=keys/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/alipay/notify/
ALIPAY_RETURN_URL=https://your-domain.com/payment/result/
