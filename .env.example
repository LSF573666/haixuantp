# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=voting_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# 短信验证码（开发环境可使用固定验证码 123456）
SMS_DEV_MODE=True
SMS_DEV_CODE=123456

# 阿里云 OSS（配置后上传文件将存储到 OSS）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
ALIYUN_OSS_BUCKET=
OSS_ENDPOINT=oss-cn-hangzhou.aliyun.com
OSS_BASE_URL=
OSS_REGION=cn-hangzhou
OSS_STS_ROLE_ARN=
OSS_STS_DURATION_SECONDS=3600

# 阿里云短信（SMS_DEV_MODE=False 时生效）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION=cn-hangzhou
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ========== 微信支付 APIv3（Native 扫码 / JSAPI + 商家转账提现）==========
# JSAPI：下单传 payment_mode=jsapi + openid，接口返回 jsapi_params 供微信内调起

# 证书/密钥文件建议放在项目 secrets/ 目录，下方填相对路径
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_MCH_SERIAL_NO=
WECHAT_PAY_MCH_PRIVATE_KEY=secrets/apiclient_key.pem
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PEM=secrets/wechat_pub_key.pem
# 提现必填：商户平台「API安全 - 微信支付公钥」公钥ID（形如 PUB_KEY_ID_xxx），不是 pem 路径
WECHAT_PAY_PLATFORM_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payments/wechat/notify/
WECHAT_PAY_WITHDRAW_NOTIFY_URL=https://your-domain.com/api/payments/withdraw/wechat/notify/
WECHAT_PAY_TRANSFER_SCENE_ID=1005

# ========== 支付宝（公钥证书模式）==========
ALIPAY_APP_ID=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_APP_PRIVATE_KEY=secrets/ALIPAY_APP_PRIVATE_KEY.pem
ALIPAY_PUBLIC_KEY=secrets/ALIPAY_PUBLIC_KEY.pem
ALIPAY_APP_CERT=secrets/appCertPublicKey_XXXXXXXX.crt
ALIPAY_ROOT_CERT=secrets/alipayRootCert.crt
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/alipay/notify/
ALIPAY_WITHDRAW_NOTIFY_URL=https://your-domain.com/api/payments/withdraw/alipay/notify/
ALIPAY_RETURN_URL=https://your-domain.com/payment/result/
